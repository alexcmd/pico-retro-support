name apple1
desc Apple I: RAM $0-$CFFF | PIA $D010 | BASIC $E000 | Monitor $FF00

# Original Apple I memory map.
# VIA stub emulates the 6820 PIA (only ORA/ORB/DDRA/DDRB used by Apple I).
# Load Woz monitor: ./scripts/write_ram.py port wozmon.bin --base 0xFF00
# Load BASIC:       ./scripts/write_ram.py port basic.bin  --base 0xE000
# Reset vector at $FFFC/$FFFD points into monitor ($FF00 area).

ram  0000  D000   # $0000-$CFFF  ~52 KB RAM
via  D010  0010   # $D010-$D01F  6820 PIA (approximated by VIA)
rom  E000  1000   # $E000-$EFFF   4 KB BASIC ROM
rom  FF00  0100   # $FF00-$FFFF  256 B  Woz monitor
